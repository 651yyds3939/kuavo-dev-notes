<?xml version="1.0" ?>

<launch>
    <arg name="robot_type"          default="humanoid"/>
    <arg name="robot_version"       default="$(optenv ROBOT_VERSION 40)"/>
    <arg name="description_name"    default="humanoid_description"/>
    <arg name="use_external_mpc"    default="true"/>
    <arg name="wbc_frequency"       default="1000"/>
    <arg name="sensor_frequency"    default="1000"/>
    <arg name="inference_frequency" default="50"/>
    <arg name="use_joystick"        default="true"/>
    <arg name="deformation_flag"    default="false"/>
    <arg name="with_estimation"     default="true"/>
    <arg name="use_joint_filter"    default="false"/>
    <arg name="estimator_type"      default="1"/>
    <arg name="wbc_only"            default="true"/>
    <arg name="play_back"           default="false"/>  
    <arg name="joystick_type"       default="bt2"/>
    <arg name="start_way"           default="manual"/>
    <arg name="rl_from_start"       default="false"/>
    <arg name="sim_keep_wbc_with_rl" default="true"/>
    <arg name="sim_rl_debug_zero_action" default="false"/>
    <arg name="sim_wbc_rl_action_blend" default="0.45"/>
    <arg name="sim_wbc_rl_blend_start" default="0.45"/>
    <arg name="sim_wbc_rl_blend_ramp_sec" default="0.0"/>
    <arg name="sim_wbc_ref_filter_tau" default="0.02"/>
    <arg name="sim_wbc_max_rl_joint_offset_rad" default="0.35"/>
    <!-- <arg name="control_frequency"   default="1000"/> -->
    
    <include file="$(find humanoid_controllers)/launch/robot_version_manager.launch">
      <arg name="robot_version" value="$(arg robot_version)"/>
    </include>
    <arg name="rl_param"  default="$(find humanoid_controllers)/config/kuavo_v$(arg robot_version)/rl/skw_rl_param.info"/>
    <arg name="network_model_file" default="$(find humanoid_controllers)/model/networks"/>

    <!-- Set with_coredump parameter based on coredump value -->
    <arg name="coredump" default="false"/>
    <arg name="with_coredump" value="--with-coredump" if="$(arg coredump)"/>
    <arg name="with_coredump" value="" unless="$(arg coredump)"/>

    <!-- 自动清理 .ros 文件夹参数 -->
    <!-- 最大日志大小为 64GB，日志大小大于 64GB 时删除日志 -->
    <param name="/nodelet_manager/max_log_size_gb" value="64.0"/>
    <!-- 删除日志到大小为 60GB 时停止删除日志 -->
    <param name="/nodelet_manager/log_delete_limit_gb" value="60.0"/>

    <!-- make the files into global parameters -->
    <param name="robot_version"               value="$(arg robot_version)"/>
     <param name="wbc_only"                   value="$(arg wbc_only)"/>
    <param name="use_external_mpc"            value="$(arg use_external_mpc)"/>
    <param name="wbc_frequency"               value="$(arg wbc_frequency)"/>
    <param name="deformation_flag"            value="$(arg deformation_flag)"/>
    <param name="sensor_frequency"            value="$(arg sensor_frequency)"/>
    <param name="with_estimation"             value="$(arg with_estimation)"/>
    <param name="use_joint_filter"            value="$(arg use_joint_filter)"/>
    <param name="estimator_type"              value="$(arg estimator_type)"/>
    <param name="joystick_type"               value="$(arg joystick_type)"/>
    <param name="play_back"                   value="$(arg play_back)"/>
    <param name="network_model_file"          value="$(arg network_model_file)"/>
    <param name="rl_param"                    value="$(arg rl_param)"/>
    <param name="inference_frequency"         value="$(arg inference_frequency)"/>
    <param name="start_way"                   value="$(arg start_way)"/>
    <param name="rl_from_start"               value="$(arg rl_from_start)"/>
    <param name="sim_keep_wbc_with_rl"        value="$(arg sim_keep_wbc_with_rl)"/>
    <param name="sim_rl_debug_zero_action"    value="$(arg sim_rl_debug_zero_action)"/>
    <param name="sim_wbc_rl_action_blend"      value="$(arg sim_wbc_rl_action_blend)"/>
    <param name="sim_wbc_rl_blend_start"       value="$(arg sim_wbc_rl_blend_start)"/>
    <param name="sim_wbc_rl_blend_ramp_sec"    value="$(arg sim_wbc_rl_blend_ramp_sec)"/>
    <param name="sim_wbc_ref_filter_tau"       value="$(arg sim_wbc_ref_filter_tau)"/>
    <param name="sim_wbc_max_rl_joint_offset_rad" value="$(arg sim_wbc_max_rl_joint_offset_rad)"/>
    <!-- <param name="control_frequency"           value="$(arg control_frequency)"/> -->
    
    <!-- nodelet manager -->
    <node pkg="nodelet" type="nodelet" name="nodelet_manager" args="manager" respawn="false" output="screen" required="true" launch-prefix="$(find humanoid_controllers)/scripts/start_node.sh $(arg with_coredump)"/>

    <node pkg="nodelet" type="nodelet" name="nodelet_controller" args="load HumanoidControllerNodelet nodelet_manager" respawn="false" output="screen" required="true" launch-prefix="$(find humanoid_controllers)/scripts/start_node.sh $(arg with_coredump)">
      </node>
    <group unless="$(arg play_back)">
      <include file="$(find mujoco_cpp)/launch/nodelet.launch"/>
    </group>
    <include file="$(find humanoid_interface)/launch/rosbag_nodelet.launch"/>
    <group if="$(arg use_joystick)">
      <group if="$(eval arg('joystick_type') == 'h12')">
        <include file="$(find humanoid_controllers)/launch/joy/joy_control_h12.launch">
          <arg name="start_way" value="$(arg start_way)"/>
        </include>
      </group>
      <group unless="$(eval arg('joystick_type') == 'h12')">
        <include file="$(find humanoid_controllers)/launch/joy/joy_control_bt.launch">
          <arg name="joystick_type" value="$(arg joystick_type)"/>
        </include>
      </group>
    </group>

     <!-- <group if="$(arg play_back)"> -->
      <!-- <include file="$(find humanoid_interface)/launch/rosbag_nodelet_player.launch"/> -->
      <!-- </group> -->
    <!-- <group if="$(arg use_joystick)">
      <include file="$(find humanoid_controllers)/launch/joy_control.launch"/>
    </group> -->
</launch>

