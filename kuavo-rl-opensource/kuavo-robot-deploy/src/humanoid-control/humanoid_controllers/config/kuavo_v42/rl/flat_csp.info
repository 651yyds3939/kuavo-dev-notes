singleInputData
{
    ; 1. 机身角速度：占据前 3 位 (0, 1, 2)
    bodyAngVel
    {
        startIdx    0
        numIdx      3
        obsScales   1.0
    }
    ; 2. 投影重力：紧随其后，占据 3 位 (3, 4, 5)
    gravity_body
    {
        startIdx    3
        numIdx      3
        obsScales   1.0
    }
    ; 3. 速度指令：紧随其后，占据 3 位 (6, 7, 8)
    command
    {
        startIdx    6
        numIdx      3
        obsScales   1.0
    }
    ; 4. 26自由度关节位置：紧随其后，占据 26 位 (9 ~ 34)
    jointPos
    {
        startIdx    9
        numIdx      26
        obsScales   1.0
    }
    ; 5. 26自由度关节速度：紧随其后，占据 26 位 (35 ~ 60)
    jointVel
    {
        startIdx    35
        numIdx      26
        obsScales   0.05 ; ⚠️ 核心注意：这里的比例必须复原为 0.05
    }
    ; 6. 上一帧动作输出：紧随其后，占据 26 位 (61 ~ 86)
    action
    {
        startIdx    61
        numIdx      26
        obsScales   1.0
    }
    ; 7. 打拳时间相位：收尾，占据最后 2 位 (87, 88)
    actionPhase 
    {
        startIdx    87
        numIdx      2
        obsScales   1.0
    }
}
