<launch>
  <!-- OctoMap 版传感器管理：加载点云 → 八叉树，供 moveit_octomap_grasp 避障规划 -->
  <rosparam command="load" file="$(find kuavo_arm_moveit_config)/config/sensors_3d_octomap.yaml" />

  <param name="octomap_frame" type="string" value="base_link" />
  <param name="octomap_resolution" type="double" value="0.03" />
  <param name="max_range" type="double" value="2.5" />

  <arg name="moveit_sensor_manager" default="biped_s49" />
  <include file="$(dirname)/$(arg moveit_sensor_manager)_moveit_sensor_manager.launch.xml" />
</launch>
